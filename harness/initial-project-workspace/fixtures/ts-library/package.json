    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "release-it": "^17.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
