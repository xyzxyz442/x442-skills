root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

[*.py]
indent_style = space
indent_size = 4

[*.ipynb]
indent_style = space
indent_size = 4

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2

[*.sh]
end_of_line = lf

[Dockerfile]
end_of_line = lf

[{package,yarn.lock}.json]
end_of_line = lf
