# Prettier 3 reads .gitignore by default (--ignore-path defaults to [.gitignore,
# .prettierignore]), so anything git ignores is already skipped. The dependency and
# build entries below are kept as a safety net for repos whose .gitignore is thinner
# than this skill's base.

# dependencies + build output
node_modules
dist
build
coverage
.venv
__pycache__

# committed, but generated or must not be reformatted
package-lock.json
pnpm-lock.yaml
yarn.lock
CHANGELOG.md
.code-review-graphignore
# handoff board index, if setup-handoff is installed: regenerated by the `handoff` CLI on every
# claim/release, so letting prettier reformat it makes the file churn on every command.
.agents/handoff/INDEX.md

