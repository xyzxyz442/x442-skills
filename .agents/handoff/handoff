#!/usr/bin/env bash
# Handoff lease manager. See README.md for the protocol.
#
# Ownership lives ONLY in .locks/<id>/ (never mirrored into the docs, so the two
# cannot desync). Durable state lives ONLY in each doc's YAML frontmatter.
# INDEX.md is generated from both and must not be hand-edited.
#
# Portable across macOS (BSD) and Linux (GNU): no `sed -i`, no `date -r`-only,
# frontmatter edits go through awk. Enforcement lives in hooks.sh.
set -uo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCKS="$DIR/.locks"
TTL_HOURS="${HANDOFF_TTL_HOURS:-4}"

# config (committed, written by setup-handoff): TOPOLOGY=single-repo|cross-repo, REPO_NAME=<name>.
# A SHARED (cross-repo) board's config carries NO REPO_NAME — identity is per-consumer, supplied via
# $HANDOFF_REPO (env). Prefer it over the shared config so audience/labeling/doc_is_local use the
# calling repo's identity, not whoever installed last. Empty on a single-repo board (uses config).
TOPOLOGY="single-repo"
REPO_NAME=""
# shellcheck disable=SC1091
[ -f "$DIR/config" ] && . "$DIR/config"
REPO_NAME="${HANDOFF_REPO:-$REPO_NAME}"

die() {
  echo "handoff: $*" >&2
  exit 1
}
now() { date +%s; }
# BSD `date -r <epoch>` vs GNU `date -d @<epoch>` — try both, fall back to the raw epoch.
human() { date -r "$1" '+%Y-%m-%d %H:%M' 2> /dev/null || date -d "@$1" '+%Y-%m-%d %H:%M' 2> /dev/null || echo "$1"; }
today() { date '+%Y-%m-%d'; }

# Raw session id — the SAME value the tool puts in its hook payload's session_id.
# hooks.sh matches session= against that payload, so this MUST be the raw id, not
# the human-readable owner string. Empty when no tool exposes one (advisory mode).
session_id() { printf '%s' "${HANDOFF_SESSION_ID:-${CLAUDE_SESSION_ID:-${CLAUDE_CODE_SESSION_ID:-}}}"; }

# Human-readable claimant, for display and the Activity log.
whoami_id() {
  local user session
  user="$(git config user.name 2> /dev/null || echo "${USER:-agent}")"
  session="$(session_id)"
  session="${session:-$$}"
  echo "${user} (${session:0:8})"
}

doc_of() { # id -> path, searching active docs then archive
  local id="$1"
  for p in "$DIR/$id.md" "$DIR/archive/$id.md"; do
    [ -f "$p" ] && {
      echo "$p"
      return
    }
  done
  die "no such handoff: $id (try: handoff list)"
}

meta() { # path key -> value from YAML frontmatter
  sed -n '2,/^---$/p' "$1" | sed -n "s/^$2:[[:space:]]*//p" | head -1
}

# Update a frontmatter key in place, or insert it before the closing --- if absent.
# Portable (awk), unlike GNU-only `sed -i 's/a/&\nb/'`.
set_field() {
  local f="$1" key="$2" val="$3" t
  t="$(mktemp)" || die "mktemp failed"
  awk -v k="$key" -v v="$val" '
    BEGIN { infm = 0; seen = 0 }
    NR == 1 && $0 == "---" { infm = 1; print; next }
    infm && $0 == "---" { if (!seen) print k": "v; infm = 0; print; next }
    infm && $0 ~ "^"k":" { print k": "v; seen = 1; next }
    { print }
  ' "$f" > "$t" && cat "$t" > "$f"
  rm -f "$t"
}

log_activity() { # path message -> append to the doc's Activity log
  local f="$1" msg="$2"
  grep -q '^## Activity' "$f" || printf '\n## Activity\n' >> "$f"
  printf -- '- %s — %s\n' "$(today)" "$msg" >> "$f"
}

lock_state() { # id -> "free" | "held|owner|exp" | "expired|owner|exp"
  local id="$1" d="$LOCKS/$1"
  [ -d "$d" ] || {
    echo "free"
    return
  }
  local owner exp
  owner="$(sed -n 's/^owner=//p' "$d/owner" 2> /dev/null || echo unknown)"
  exp="$(sed -n 's/^expires=//p' "$d/owner" 2> /dev/null || echo 0)"
  if [ "$(now)" -ge "${exp:-0}" ]; then echo "expired|$owner|$exp"; else echo "held|$owner|$exp"; fi
}

is_archived() { [ -f "$DIR/archive/$1.md" ]; }

# Handoff type. "standalone" = a self-contained reference/knowledge doc: gate-exempt (no lease
# needed to edit) and not surfaced as claimable work. "coordination" (the default, and what an
# absent `type:` means) = a lease-gated work item. Keep the absence⇒coordination rule so legacy
# docs and existing boards behave exactly as before.
doc_type() {
  local t
  t="$(meta "$1" type)"
  printf '%s' "${t:-coordination}"
}
is_standalone() { [ "$(doc_type "$1")" = "standalone" ]; }

# The redaction reminder embedded at the top of every generated doc body. A handoff doc is
# committed to git history, so secrets pasted into it persist. Kept as a function so the coordination
# and standalone fallback templates stay identical.
redaction_comment() {
  echo "<!-- NEVER COMMIT SECRETS. This doc is committed to git history. Redact any keys,"
  echo "     secrets, passwords, confidential data, or PII. If a credential is truly needed,"
  echo "     prompt the user and record its NAME (env var / secret-manager ref), never the value. -->"
}

# Release a lease: remove its files then the now-empty dir. rmdir only removes an empty
# directory, so this never recursively deletes anything unexpected (no `rm -rf`).
clear_lock() {
  rm -f "$LOCKS/$1/owner" 2> /dev/null
  rmdir "$LOCKS/$1" 2> /dev/null || true
}

cmd_new() {
  local id="" title="" audience="" severity="medium" note="" type="coordination"
  id="${1:?usage: handoff new <id> [--title T] [--type coordination|standalone] [--standalone] [--audience REPO] [--severity S] [--note N]}"
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --title)
        title="${2:-}"
        shift 2
        ;;
      --audience)
        audience="${2:-}"
        shift 2
        ;;
      --severity)
        severity="${2:-}"
        shift 2
        ;;
      --note)
        note="${2:-}"
        shift 2
        ;;
      --type)
        type="${2:-}"
        shift 2
        ;;
      --standalone)
        type="standalone"
        shift
        ;;
      *) shift ;;
    esac
  done
  case "$type" in coordination | standalone) ;; *) die "bad --type: $type (use coordination|standalone)" ;; esac
  [ -f "$DIR/$id.md" ] || [ -f "$DIR/archive/$id.md" ] && die "$id already exists"
  [ -n "$title" ] || title="$id"
  local d
  d="$(today)"

  if [ "$type" = "standalone" ]; then
    # A standalone/reference doc: gate-exempt, self-contained, no audience/severity/lease.
    local tmpl="$DIR/handoff-standalone-template.md"
    if [ -f "$tmpl" ]; then
      sed -e "s|PLACEHOLDER_ID|$id|g" -e "s|PLACEHOLDER_TITLE|$title|g" \
        -e "s|PLACEHOLDER_CREATED|$d|g" -e "s|PLACEHOLDER_UPDATED|$d|g" \
        -e "s|PLACEHOLDER_NOTE|$note|g" "$tmpl" > "$DIR/$id.md"
    else
      {
        echo "---"
        echo "id: $id"
        echo "title: $title"
        echo "type: standalone"
        echo "status: open"
        echo "created: $d"
        echo "updated: $d"
        echo "note: $note"
        echo "---"
        echo
        redaction_comment
        echo
        echo "## Summary"
        echo
        echo "## Context"
        echo
        echo "## Suggested skills"
        echo
      } > "$DIR/$id.md"
    fi
    echo "Created $DIR/$id.md (standalone/reference) — no claim needed; edit it freely."
  else
    if [ "$TOPOLOGY" = "cross-repo" ] && [ -z "$audience" ]; then
      # Shared board: no single default identity. Use the calling repo's env identity if present,
      # otherwise require an explicit --audience rather than defaulting to a stale/foreign name.
      if [ -n "${HANDOFF_REPO:-}" ]; then
        audience="$HANDOFF_REPO"
      else die "cross-repo board: pass --audience <repo> (which repo acts next) — a shared board has no default identity"; fi
    fi
    local tmpl="$DIR/handoff-doc-template.md"
    if [ -f "$tmpl" ]; then
      # PLACEHOLDER_* tokens (not {{...}} or <...>) so a prettier/lint pass on the shipped
      # template never mangles them before `handoff new` fills them in.
      sed -e "s|PLACEHOLDER_ID|$id|g" -e "s|PLACEHOLDER_TITLE|$title|g" -e "s|PLACEHOLDER_AUDIENCE|$audience|g" \
        -e "s|PLACEHOLDER_SEVERITY|$severity|g" -e "s|PLACEHOLDER_CREATED|$d|g" -e "s|PLACEHOLDER_UPDATED|$d|g" \
        -e "s|PLACEHOLDER_NOTE|$note|g" "$tmpl" > "$DIR/$id.md"
    else
      {
        echo "---"
        echo "id: $id"
        echo "title: $title"
        echo "type: coordination"
        echo "status: open"
        [ -n "$audience" ] && echo "audience: $audience"
        echo "severity: $severity"
        echo "created: $d"
        echo "updated: $d"
        echo "note: $note"
        echo "---"
        echo
        redaction_comment
        echo
        echo "## Context"
        echo
        echo "## Verify"
        echo
        echo "## Suggested skills"
        echo
      } > "$DIR/$id.md"
    fi
    echo "Created $DIR/$id.md — claim it before working: ./handoff claim $id \"...\""
  fi
  echo "🔒 Before committing: redact secrets/keys/passwords/PII — this doc goes into git history."
  cmd_index
}

# Bring an existing file onto the board as a handoff (default type: standalone). Used to migrate
# reference docs. Never moves the source (the caller trashes it); we copy + normalize frontmatter.
cmd_import() {
  local src="" id="" title="" type="standalone" severity="" note=""
  src="${1:?usage: handoff import <file> [--id ID] [--title T] [--type standalone|coordination] [--severity S] [--note N]}"
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --id)
        id="${2:-}"
        shift 2
        ;;
      --title)
        title="${2:-}"
        shift 2
        ;;
      --type)
        type="${2:-}"
        shift 2
        ;;
      --severity)
        severity="${2:-}"
        shift 2
        ;;
      --note)
        note="${2:-}"
        shift 2
        ;;
      --standalone)
        type="standalone"
        shift
        ;;
      *) shift ;;
    esac
  done
  [ -f "$src" ] || die "no such file: $src"
  case "$type" in coordination | standalone) ;; *) die "bad --type: $type (use coordination|standalone)" ;; esac
  [ -n "$id" ] || id="$(basename "$src" .md)"
  # sanitize id to a safe slug (the filename becomes .agents/handoff/<id>.md)
  id="$(printf '%s' "$id" | tr ' /' '--' | tr -cd 'A-Za-z0-9._-')"
  [ -n "$id" ] || die "could not derive an id from $src — pass --id"
  [ -f "$DIR/$id.md" ] || [ -f "$DIR/archive/$id.md" ] && die "$id already exists on the board"
  # title: --title, else the first markdown H1, else the id
  [ -n "$title" ] || title="$(sed -n 's/^# //p' "$src" | head -1)"
  [ -n "$title" ] || title="$id"
  local d
  d="$(today)" dest="$DIR/$id.md"

  if [ "$(head -1 "$src")" = "---" ]; then
    # Source already has YAML frontmatter — copy it, then upsert the board keys via set_field.
    cp "$src" "$dest"
    set_field "$dest" id "$id"
    set_field "$dest" title "$title"
    set_field "$dest" type "$type"
    [ -n "$(meta "$dest" status)" ] || set_field "$dest" status "open"
    [ -n "$(meta "$dest" created)" ] || set_field "$dest" created "$d"
    set_field "$dest" updated "$d"
    [ "$type" = "coordination" ] && [ -n "$severity" ] && set_field "$dest" severity "$severity"
  else
    # No frontmatter — prepend a fresh block above the content, verbatim.
    {
      echo "---"
      echo "id: $id"
      echo "title: $title"
      echo "type: $type"
      echo "status: open"
      [ "$type" = "coordination" ] && echo "severity: ${severity:-medium}"
      echo "created: $d"
      echo "updated: $d"
      echo "note: $note"
      echo "---"
      echo
    } > "$dest"
    cat "$src" >> "$dest"
  fi
  echo "Imported $src → $dest (type: $type)."
  echo "🔒 Before committing: redact secrets/keys/passwords/PII — this doc goes into git history."
  cmd_index
}

cmd_list() {
  printf '%-44s %-9s %-14s %-8s %s\n' ID STATUS AUDIENCE SEVERITY LOCK
  printf '%-44s %-9s %-14s %-8s %s\n' "$(printf '%.44s' "--------------------------------------------")" \
    "---------" "--------------" "--------" "----"
  local standalone=""
  for f in "$DIR"/*.md; do
    [ -f "$f" ] || continue
    local base
    base="$(basename "$f" .md)"
    case "$base" in INDEX | README | handoff-doc-template | handoff-standalone-template) continue ;; esac
    if is_standalone "$f"; then
      standalone="${standalone}$(printf '%-44s %-9s %s' "$base" "$(meta "$f" status)" "$(meta "$f" title)")"$'\n'
      continue
    fi
    local kind owner exp
    IFS='|' read -r kind owner exp <<< "$(lock_state "$base")"
    local lock='—'
    case "$kind" in
      held) lock="🔒 $owner until $(human "$exp")" ;;
      expired) lock="⚠️  STALE $owner (expired $(human "$exp")) — reclaimable" ;;
    esac
    printf '%-44s %-9s %-14s %-8s %s\n' \
      "$base" "$(meta "$f" status)" "$(meta "$f" audience)" "$(meta "$f" severity)" "$lock"
  done
  if [ -n "$standalone" ]; then
    printf '\nStandalone / reference (no claim needed):\n'
    printf '%-44s %-9s %s\n' ID STATUS TITLE
    printf '%s' "$standalone"
  fi
}

cmd_claim() {
  local id="${1:?usage: handoff claim <id> [note]}"
  shift || true
  local note="${*:-}"
  local f
  f="$(doc_of "$id")"
  is_standalone "$f" && die "$id is a standalone/reference handoff — no lease needed; just edit it."
  [ "$(meta "$f" status)" = "done" ] && die "$id is already done — nothing to claim"

  local kind owner exp
  IFS='|' read -r kind owner exp <<< "$(lock_state "$id")"
  if [ "$kind" = "held" ]; then
    die "$id is CLAIMED by $owner until $(human "$exp"). Do not work on it — pick another handoff, or ask $owner."
  fi

  # Atomic: mkdir fails if the directory already exists, so two racing agents
  # cannot both win the lease. Do not replace this with a frontmatter edit.
  # .locks/ itself is gitignored and may not exist on a fresh install — create the
  # parent (non-atomic, fine) so the per-id mkdir (atomic, the real lock) can run.
  mkdir -p "$LOCKS"
  if ! mkdir "$LOCKS/$id" 2> /dev/null; then
    die "$id was just claimed by someone else — re-run 'handoff list'"
  fi

  local me sess exp_new
  me="$(whoami_id)"
  sess="$(session_id)"
  exp_new="$(($(now) + TTL_HOURS * 3600))"
  {
    echo "owner=$me"
    echo "session=$sess" # raw id — the enforcement gate matches this against the tool payload
    echo "claimed=$(now)"
    echo "expires=$exp_new"
    echo "note=$note"
  } > "$LOCKS/$id/owner"

  if [ "$kind" = "expired" ]; then
    echo "⚠️  Took over an EXPIRED lease from $owner (expired $(human "$exp"))."
    log_activity "$f" "lease taken over from $owner (expired $(human "$exp")) by $me"
  fi
  echo "🔒 Claimed $id as $me for ${TTL_HOURS}h (until $(human "$exp_new")). Release it when you stop."
  cmd_index
}

cmd_touch() {
  local id="${1:?usage: handoff touch <id>}"
  local kind owner exp
  IFS='|' read -r kind owner exp <<< "$(lock_state "$id")"
  [ "$kind" = "free" ] && die "$id is not claimed"
  # rewrite the lease with a fresh expiry, preserving the other fields
  local t
  t="$(mktemp)"
  grep -v '^expires=' "$LOCKS/$id/owner" > "$t"
  echo "expires=$(($(now) + TTL_HOURS * 3600))" >> "$t"
  cat "$t" > "$LOCKS/$id/owner"
  rm -f "$t"
  echo "Lease on $id extended ${TTL_HOURS}h."
}

cmd_release() {
  local id="${1:?usage: handoff release <id> --status open|blocked|done [--verified-by \"...\"] [--blocked-on \"...\"] [--run-verify] [note]}"
  shift
  local status='' note='' verified_by='' blocked_on='' run_verify=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --status)
        status="${2:?}"
        shift 2
        ;;
      --verified-by)
        verified_by="${2:?}"
        shift 2
        ;;
      --blocked-on)
        blocked_on="${2:?}"
        shift 2
        ;;
      --run-verify)
        run_verify=1
        shift
        ;;
      *)
        note="$note $1"
        shift
        ;;
    esac
  done
  [ -n "$status" ] || die "release needs --status open|blocked|done"
  case "$status" in open | blocked | done) ;; *) die "bad status: $status" ;; esac

  local f
  f="$(doc_of "$id")"
  local me
  me="$(whoami_id)"

  if is_standalone "$f"; then
    # A standalone/reference doc carries no lease and makes no live-code claim, so `done`
    # just retires it (archive) with no --verified-by. Only open|done apply.
    case "$status" in
      open)
        set_field "$f" status open
        set_field "$f" updated "$(today)"
        log_activity "$f" "updated (standalone) by $me.${note}"
        echo "Updated standalone $id."
        ;;
      done)
        set_field "$f" status done
        set_field "$f" updated "$(today)"
        log_activity "$f" "retired (standalone) by $me.${note}"
        mkdir -p "$DIR/archive"
        if [ "$(dirname "$f")" = "$DIR" ]; then
          git -C "$DIR" mv "$(basename "$f")" "archive/$(basename "$f")" 2> /dev/null \
            || mv "$f" "$DIR/archive/" 2> /dev/null || true
        fi
        echo "✅ Retired standalone $id → archive/."
        ;;
      *) die "standalone handoffs support --status open|done (there is no lease to block on)" ;;
    esac
    cmd_index
    return
  fi

  if [ "$status" = "blocked" ]; then
    [ -n "$blocked_on" ] || die "release --status blocked needs --blocked-on <handoff-id|\"external: ...\"> — what is it waiting on?"
    set_field "$f" blocked_on "$blocked_on"
  fi

  if [ "$status" = "done" ]; then
    # done is a claim about the LIVE CODE, not about the doc. Require evidence.
    [ -n "$verified_by" ] || die "release --status done needs --verified-by \"<how you verified against live code>\" (e.g. a test run or file:line). Trust-closing is disabled."
    local vcmd
    vcmd="$(meta "$f" verify)"
    if [ -n "$vcmd" ]; then
      # SAFE BY DEFAULT: never auto-run a command from a doc (a cross-repo doc is
      # untrusted). Run only with BOTH an explicit flag AND the install-time opt-in,
      # and only for a doc whose origin is THIS repo.
      if [ "$run_verify" = 1 ] && [ "${HANDOFF_ALLOW_VERIFY_CMD:-0}" = 1 ] && doc_is_local "$f"; then
        echo "Running verify: $vcmd"
        if ! (cd "$(git rev-parse --show-toplevel 2> /dev/null || echo "$DIR")" && eval "$vcmd"); then
          die "verify command failed — not closing $id. Fix the code or the command."
        fi
        verified_by="$verified_by [verify: exit 0]"
      else
        echo "NOTE: this handoff carries a verify: command but it was NOT run"
        echo "      ($vcmd)"
        echo "      Run it yourself, or re-release with --run-verify (needs install opt-in HANDOFF_ALLOW_VERIFY_CMD=1 and a local doc)."
      fi
    fi
  fi

  set_field "$f" status "$status"
  set_field "$f" updated "$(today)"
  if [ "$status" = "done" ]; then
    set_field "$f" verified_at "$(today)"
    log_activity "$f" "done — verified against live code by $me: ${verified_by}.${note}"
    mkdir -p "$DIR/archive"
    if [ "$(dirname "$f")" = "$DIR" ]; then
      git -C "$DIR" mv "$(basename "$f")" "archive/$(basename "$f")" 2> /dev/null \
        || mv "$f" "$DIR/archive/" 2> /dev/null || true
    fi
    echo "✅ $id → done, moved to archive/. verified-by: $verified_by"
    echo "🔒 This doc is committed to git history — confirm no secrets/keys/passwords/PII remain."
    surface_unblocked "$id"
  else
    log_activity "$f" "$status — released by $me.${note}"
    echo "Released $id → $status."
  fi
  clear_lock "$id"
  cmd_index
}

doc_is_local() { # a doc "belongs to" this repo when repos: is unset or names REPO_NAME
  local f="$1" repos
  repos="$(meta "$f" repos)"
  [ -z "$repos" ] && return 0
  [ -z "$REPO_NAME" ] && return 0
  case "$repos" in *"$REPO_NAME"*) return 0 ;; *) return 1 ;; esac
}

surface_unblocked() { # closed_id -> print any open docs blocked_on it
  local closed="$1" found=0
  for g in "$DIR"/*.md; do
    [ -f "$g" ] || continue
    local gb
    gb="$(basename "$g" .md)"
    case "$gb" in INDEX | README | handoff-doc-template | handoff-standalone-template) continue ;; esac
    [ "$(meta "$g" status)" = "blocked" ] || continue
    case "$(meta "$g" blocked_on)" in *"$closed"*)
      [ "$found" = 0 ] && echo "Now unblocked (their blocker $closed is done):"
      found=1
      echo "  - $gb — $(meta "$g" title)"
      ;;
    esac
  done
  return 0
}

cmd_reap() { # show (and with --force, clear) expired leases
  local force="${1:-}"
  local found=0
  for d in "$LOCKS"/*/; do
    [ -d "$d" ] || continue
    local id
    id="$(basename "$d")"
    local kind owner exp
    IFS='|' read -r kind owner exp <<< "$(lock_state "$id")"
    [ "$kind" = "expired" ] || continue
    found=1
    echo "⚠️  $id — held by $owner, expired $(human "$exp")"
    if [ "$force" = "--force" ]; then
      clear_lock "$id"
      echo "   cleared."
    fi
  done
  [ "$found" = 0 ] && echo "No expired leases."
  return 0
}

cmd_index() {
  local out="$DIR/INDEX.md"
  {
    echo "<!-- GENERATED by ./handoff index — do not edit by hand. -->"
    echo "# Handoff Index"
    echo
    if [ "$TOPOLOGY" = "cross-repo" ]; then
      echo "Shared coordination board${REPO_NAME:+ (viewed as $REPO_NAME)}. Generated $(date '+%Y-%m-%d %H:%M')."
    else
      echo "Coordination board for ${REPO_NAME:-this repo}. Generated $(date '+%Y-%m-%d %H:%M')."
    fi
    echo "Claim before you work: \`./handoff claim <id>\`. Protocol: [README.md](./README.md)."
    echo
    echo "## Open"
    echo
    echo "| Handoff | Status | Acts next | Severity | Updated | Blocked on | Lease |"
    echo "| --- | --- | --- | --- | --- | --- | --- |"
    for f in "$DIR"/*.md; do
      [ -f "$f" ] || continue
      local base
      base="$(basename "$f" .md)"
      case "$base" in INDEX | README | handoff-doc-template | handoff-standalone-template) continue ;; esac
      is_standalone "$f" && continue
      local kind owner exp
      IFS='|' read -r kind owner exp <<< "$(lock_state "$base")"
      local lease="—"
      [ "$kind" = "held" ] && lease="🔒 $owner"
      [ "$kind" = "expired" ] && lease="⚠️ stale ($owner)"
      local bo
      bo="$(meta "$f" blocked_on)"
      [ -n "$bo" ] && is_archived "${bo%% *}" && bo="$bo ✅ resolved"
      echo "| [$(meta "$f" title)](./$base.md) | \`$(meta "$f" status)\` | $(meta "$f" audience) | $(meta "$f" severity) | $(meta "$f" updated) | ${bo:-—} | $lease |"
    done
    echo
    # Standalone / reference docs: self-contained, gate-exempt, no lease. Listed apart so they
    # are not mistaken for claimable work.
    local has_standalone=0
    for f in "$DIR"/*.md; do
      [ -f "$f" ] || continue
      local base
      base="$(basename "$f" .md)"
      case "$base" in INDEX | README | handoff-doc-template | handoff-standalone-template) continue ;; esac
      is_standalone "$f" || continue
      if [ "$has_standalone" = 0 ]; then
        has_standalone=1
        echo "## Standalone / reference (no claim needed)"
        echo
        echo "| Handoff | Status | Updated |"
        echo "| --- | --- | --- |"
      fi
      echo "| [$(meta "$f" title)](./$base.md) | \`$(meta "$f" status)\` | $(meta "$f" updated) |"
    done
    [ "$has_standalone" = 1 ] && echo
    echo "## Archive (done / superseded)"
    echo
    echo "| Handoff | Status | Verified |"
    echo "| --- | --- | --- |"
    for f in "$DIR"/archive/*.md; do
      [ -f "$f" ] || continue
      local base
      base="$(basename "$f" .md)"
      echo "| [$(meta "$f" title)](./archive/$base.md) | \`$(meta "$f" status)\` | $(meta "$f" verified_at) |"
    done
  } > "$out"
  echo "Wrote $out"
}

case "${1:-list}" in
  list) cmd_list ;;
  new)
    shift
    cmd_new "$@"
    ;;
  import)
    shift
    cmd_import "$@"
    ;;
  claim)
    shift
    cmd_claim "$@"
    ;;
  touch)
    shift
    cmd_touch "$@"
    ;;
  release)
    shift
    cmd_release "$@"
    ;;
  reap)
    shift
    cmd_reap "$@"
    ;;
  index) cmd_index ;;
  *) die "usage: handoff [list | new <id> [--type coordination|standalone|--standalone] [opts] | import <file> [--id ID] [--title T] [--type ...] | claim <id> [note] | touch <id> | release <id> --status open|blocked|done [--verified-by ...] [--blocked-on ...] [--run-verify] | reap [--force] | index]" ;;
esac
