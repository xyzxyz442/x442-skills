#!/usr/bin/env bash
# Handoff lease manager. See README.md for the protocol.
#
# Ownership lives ONLY in .locks/<id>/ (never mirrored into the docs, so the two
# cannot desync). Durable state lives ONLY in each doc's YAML frontmatter.
# INDEX.md is generated from both and must not be hand-edited.
#
# Portable across macOS (BSD) and Linux (GNU): no `sed -i`, no `date -r`-only,
# frontmatter edits go through awk. Enforcement lives in hooks.sh.
set -uo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCKS="$DIR/.locks"
TTL_HOURS="${HANDOFF_TTL_HOURS:-4}"

# config (committed, written by setup-handoff): TOPOLOGY=single-repo|cross-repo, REPO_NAME=<name>.
# A SHARED (cross-repo) board's config carries NO REPO_NAME — identity is per-consumer, supplied via
# $HANDOFF_REPO (env). Prefer it over the shared config so audience/labeling/doc_is_local use the
# calling repo's identity, not whoever installed last. Empty on a single-repo board (uses config).
TOPOLOGY="single-repo"
REPO_NAME=""
# shellcheck disable=SC1091
[ -f "$DIR/config" ] && . "$DIR/config"
REPO_NAME="${HANDOFF_REPO:-$REPO_NAME}"

die() {
  echo "handoff: $*" >&2
  exit 1
}
now() { date +%s; }
# BSD `date -r <epoch>` vs GNU `date -d @<epoch>` — try both, fall back to the raw epoch.
human() { date -r "$1" '+%Y-%m-%d %H:%M' 2> /dev/null || date -d "@$1" '+%Y-%m-%d %H:%M' 2> /dev/null || echo "$1"; }
today() { date '+%Y-%m-%d'; }

# Raw session id — the SAME value the tool puts in its hook payload's session_id.
# hooks.sh matches session= against that payload, so this MUST be the raw id, not
# the human-readable owner string. Empty when no tool exposes one (advisory mode).
session_id() { printf '%s' "${HANDOFF_SESSION_ID:-${CLAUDE_SESSION_ID:-${CLAUDE_CODE_SESSION_ID:-}}}"; }

# Human-readable claimant, for display and the Activity log.
whoami_id() {
  local user session
  user="$(git config user.name 2> /dev/null || echo "${USER:-agent}")"
  session="$(session_id)"
  session="${session:-$$}"
  echo "${user} (${session:0:8})"
}

doc_of() { # id -> path, searching active docs then archive
  local id="$1"
  for p in "$DIR/$id.md" "$DIR/archive/$id.md"; do
    [ -f "$p" ] && {
      echo "$p"
      return
    }
  done
  die "no such handoff: $id (try: handoff list)"
}

meta() { # path key -> value from YAML frontmatter
  sed -n '2,/^---$/p' "$1" | sed -n "s/^$2:[[:space:]]*//p" | head -1
}

# Update a frontmatter key in place, or insert it before the closing --- if absent.
# Portable (awk), unlike GNU-only `sed -i 's/a/&\nb/'`.
set_field() {
  local f="$1" key="$2" val="$3" t
  t="$(mktemp)" || die "mktemp failed"
  awk -v k="$key" -v v="$val" '
    BEGIN { infm = 0; seen = 0 }
    NR == 1 && $0 == "---" { infm = 1; print; next }
    infm && $0 == "---" { if (!seen) print k": "v; infm = 0; print; next }
    infm && $0 ~ "^"k":" { print k": "v; seen = 1; next }
    { print }
  ' "$f" > "$t" && cat "$t" > "$f"
  rm -f "$t"
}

log_activity() { # path message -> append to the doc's Activity log
  local f="$1" msg="$2"
  # the blank line after the heading is required — without it markdownlint flags every doc
  # (MD022 blanks-around-headings / MD032 blanks-around-lists) the moment the first entry lands
  grep -q '^## Activity' "$f" || printf '\n## Activity\n\n' >> "$f"
  printf -- '- %s — %s\n' "$(today)" "$msg" >> "$f"
}

lock_state() { # id -> "free" | "held|owner|exp" | "expired|owner|exp"
  local id="$1" d="$LOCKS/$1"
  [ -d "$d" ] || {
    echo "free"
    return
  }
  local owner exp
  owner="$(sed -n 's/^owner=//p' "$d/owner" 2> /dev/null || echo unknown)"
  exp="$(sed -n 's/^expires=//p' "$d/owner" 2> /dev/null || echo 0)"
  if [ "$(now)" -ge "${exp:-0}" ]; then echo "expired|$owner|$exp"; else echo "held|$owner|$exp"; fi
}

is_archived() { [ -f "$DIR/archive/$1.md" ]; }

# Handoff type. "standalone" = a self-contained reference/knowledge doc: gate-exempt (no lease
# needed to edit) and not surfaced as claimable work. "coordination" (the default, and what an
# absent `type:` means) = a lease-gated work item. Keep the absence⇒coordination rule so legacy
# docs and existing boards behave exactly as before.
doc_type() {
  local t
  t="$(meta "$1" type)"
  printf '%s' "${t:-coordination}"
}
is_standalone() { [ "$(doc_type "$1")" = "standalone" ]; }
is_orchestrator() { [ "$(doc_type "$1")" = "orchestrator" ]; }

# An orchestrator tracks a BUNDLE of related handoffs. It holds no work of its own, so like a
# standalone it needs no lease and is gate-exempt; unlike a standalone it is not a reference doc but
# an index whose progress is DERIVED from its children every time it is read. Nothing about child
# status is stored on the orchestrator — a stored count would desync the moment a child closed
# without the parent being updated, which is exactly the rot this doc is meant to prevent.
children_of() { # path -> newline-separated child ids (canonicalized)
  local raw c
  raw="$(meta "$1" children)"
  raw="${raw#[}"
  raw="${raw%]}"
  # Split on commas with IFS rather than `tr ',' '\n' | while read`: that pipeline silently DROPS
  # the last element, because the final field carries no trailing newline and `read` returns
  # non-zero on it, ending the loop before the body runs. A bundle quietly losing its last child is
  # exactly the kind of miscount this doc type exists to prevent.
  local IFS=','
  for c in $raw; do
    c="$(printf '%s' "$c" | tr -d '"[:space:]')"
    [ -n "$c" ] || continue
    resolve_id "$c" || continue
    printf '\n'
  done
}

# "<done>/<total>" plus the ids still outstanding. A child that names no file counts as missing, not
# as done — a typo must never read as progress.
child_progress() { # path -> "done|total|outstanding-csv"
  local total=0 done=0 out="" cf st
  while IFS= read -r c; do
    [ -n "$c" ] || continue
    total=$((total + 1))
    cf=""
    [ -f "$DIR/$c.md" ] && cf="$DIR/$c.md"
    [ -z "$cf" ] && [ -f "$DIR/archive/$c.md" ] && cf="$DIR/archive/$c.md"
    if [ -z "$cf" ]; then
      out="${out:+$out, }$c (MISSING)"
      continue
    fi
    st="$(meta "$cf" status)"
    if [ "$st" = "done" ]; then done=$((done + 1)); else out="${out:+$out, }$c ($st)"; fi
  done <<< "$(children_of "$1")"
  printf '%s|%s|%s' "$done" "$total" "$out"
}

# Every handoff doc file is named "<id>-handoff.md" and the id IS the filename stem. norm_id
# canonicalizes any user-supplied id to that form (idempotent — never doubles the suffix), so
# `new rbac-gap`, `claim rbac-gap`, and `claim rbac-gap-handoff` all resolve to rbac-gap-handoff.
#
# Ids are compared as literal strings everywhere — lease directory names under .locks/, blocked_on
# cross-references, INDEX.md rows, and the hooks' case-sensitive *-handoff.md gate. So the id must
# also be slugified to lowercase kebab-case, or "RBAC Gap" and "rbac-gap" become two leases over
# one doc (and on a case-insensitive filesystem the edit gate silently fails open). Lowercasing
# happens BEFORE the suffix test, so "RBAC-Handoff" yields rbac-handoff, not rbac-handoff-handoff.
# Returns non-zero on an id that slugifies to nothing ("!!!"), so callers can die with usage.
norm_id() {
  local s
  s="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' | sed -e 's/--*/-/g' -e 's/^-//' -e 's/-$//')"
  [ -n "$s" ] || return 1
  case "$s" in *-handoff) printf '%s' "$s" ;; *) printf '%s-handoff' "$s" ;; esac
}

# The pre-slug spelling of an id: suffix-only canonicalization, no case/separator folding. This is
# what norm_id did before ids were slugified, and it is the only thing legacy_id is for.
legacy_id() { case "$1" in *-handoff) printf '%s' "$1" ;; *) printf '%s-handoff' "$1" ;; esac }

# Resolve a user-supplied id to the id an EXISTING doc actually uses. Prefers the canonical slug,
# but falls back to the pre-slug spelling when only that file exists — otherwise slugifying would
# orphan docs on boards installed before this rule (their filenames are not being migrated: a
# rename breaks blocked_on cross-references and git history for a cosmetic gain). Creation never
# calls this — `new`/`import` always slugify, so no new non-conforming file is ever created.
resolve_id() {
  local want raw
  want="$(norm_id "$1")" || return 1
  if [ -f "$DIR/$want.md" ] || [ -f "$DIR/archive/$want.md" ]; then
    printf '%s' "$want"
    return
  fi
  raw="$(legacy_id "$1")"
  if [ -f "$DIR/$raw.md" ] || [ -f "$DIR/archive/$raw.md" ]; then
    printf '%s' "$raw"
    return
  fi
  printf '%s' "$want" # neither exists — return canonical so doc_of reports it by its proper name
}

# The redaction reminder embedded at the top of every generated doc body. A handoff doc is
# committed to git history, so secrets pasted into it persist. Kept as a function so the coordination
# and standalone fallback templates stay identical.
redaction_comment() {
  echo "<!-- NEVER COMMIT SECRETS. This doc is committed to git history. Redact any keys,"
  echo "     secrets, passwords, confidential data, or PII. If a credential is truly needed,"
  echo "     prompt the user and record its NAME (env var / secret-manager ref), never the value. -->"
}

# Templates live in <board>/templates/. The flat fallback covers a board installed before the
# restructure (templates sat next to the CLI); when neither exists the callers fall back to an
# inline heredoc, so a missing template is never fatal.
tmpl_path() {
  if [ -f "$DIR/templates/$1" ]; then
    printf '%s' "$DIR/templates/$1"
  else
    printf '%s' "$DIR/$1"
  fi
}

# Fill a template's PLACEHOLDER_* tokens with literal values.
#
# This must NOT be `sed "s|PLACEHOLDER_NOTE|$note|"`. The value comes from --title/--note, i.e.
# arbitrary user text: a `|` in it closes the s/// expression early (sed then reads the remainder as
# a filename and fails), and `&` in a replacement expands to the whole match. The redirection has
# already truncated the destination by then, so the failure lands as a ZERO-BYTE handoff doc while
# the command still reports success. Bash's ${var//pat/rep} substitutes literally, needs no external
# process, and cannot be broken by any character in the value.
render_tmpl() { # tmpl-path KEY=value...
  local content
  content="$(cat "$1")" || return 1
  shift
  local kv k v
  for kv in "$@"; do
    k="${kv%%=*}"
    v="${kv#*=}"
    content="${content//$k/$v}"
  done
  printf '%s\n' "$content"
}

# Release a lease: remove its files then the now-empty dir. rmdir only removes an empty
# directory, so this never recursively deletes anything unexpected (no `rm -rf`).
clear_lock() {
  rm -f "$LOCKS/$1/owner" 2> /dev/null
  rmdir "$LOCKS/$1" 2> /dev/null || true
}

cmd_new() {
  local id="" title="" audience="" severity="medium" note="" type="coordination" children=""
  id="${1:?usage: handoff new <id> [--title T] [--type coordination|standalone|orchestrator] [--standalone] [--orchestrator --children a,b,c] [--audience REPO] [--severity S] [--note N]}"
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --title)
        title="${2:-}"
        shift 2
        ;;
      --audience)
        audience="${2:-}"
        shift 2
        ;;
      --severity)
        severity="${2:-}"
        shift 2
        ;;
      --note)
        note="${2:-}"
        shift 2
        ;;
      --type)
        type="${2:-}"
        shift 2
        ;;
      --standalone)
        type="standalone"
        shift
        ;;
      --orchestrator)
        type="orchestrator"
        shift
        ;;
      --children)
        children="${2:-}"
        shift 2
        ;;
      *) shift ;;
    esac
  done
  case "$type" in coordination | standalone | orchestrator) ;; *) die "bad --type: $type (use coordination|standalone|orchestrator)" ;; esac
  [ -n "$children" ] && [ "$type" != "orchestrator" ] && die "--children only applies to --orchestrator"
  # files are always <id>-handoff.md and the id is a lowercase-kebab slug of what the caller passed
  local raw_id="$id"
  id="$(norm_id "$id")" || die "unusable id: '$raw_id' (needs at least one letter or digit)"
  [ -f "$DIR/$id.md" ] || [ -f "$DIR/archive/$id.md" ] && die "$id already exists"
  [ -n "$title" ] || title="$id"
  local d
  d="$(today)"

  if [ "$type" = "orchestrator" ]; then
    # An orchestrator: an index over a bundle of related handoffs. Gate-exempt (no lease), no
    # audience/severity of its own. Children are canonicalized here so `--children rbac-gap` and
    # `--children rbac-gap-handoff` record the same id; progress is derived at read time, never
    # stored. A child that does not exist yet is allowed — a bundle is often planned before it is
    # filed — but `list` reports it as MISSING rather than counting it toward progress.
    local clist=""
    local c
    for c in $(printf '%s' "$children" | tr ',' ' '); do
      c="$(norm_id "$c")" || die "unusable child id: '$c'"
      clist="${clist:+$clist, }$c"
    done
    local tmpl
    tmpl="$(tmpl_path handoff-orchestrator-template.md)"
    if [ -f "$tmpl" ]; then
      render_tmpl "$tmpl" "PLACEHOLDER_ID=$id" "PLACEHOLDER_TITLE=$title" \
        "PLACEHOLDER_CREATED=$d" "PLACEHOLDER_UPDATED=$d" \
        "PLACEHOLDER_CHILDREN=$clist" "PLACEHOLDER_NOTE=$note" > "$DIR/$id.md"
    else
      {
        echo "---"
        echo "id: $id"
        echo "title: $title"
        echo "type: orchestrator"
        echo "status: open"
        echo "children: [$clist]"
        echo "created: $d"
        echo "updated: $d"
        echo "note: $note"
        echo "---"
        echo
        redaction_comment
        echo
        echo "## Bundle"
        echo
        echo "## Sequencing"
        echo
        echo "## Suggested skills"
        echo
      } > "$DIR/$id.md"
    fi
    echo "Created $DIR/$id.md (orchestrator over ${clist:-no children yet}) — no claim needed."
  elif [ "$type" = "standalone" ]; then
    # A standalone/reference doc: gate-exempt, self-contained, no audience/severity/lease.
    local tmpl
    tmpl="$(tmpl_path handoff-standalone-template.md)"
    if [ -f "$tmpl" ]; then
      render_tmpl "$tmpl" "PLACEHOLDER_ID=$id" "PLACEHOLDER_TITLE=$title" \
        "PLACEHOLDER_CREATED=$d" "PLACEHOLDER_UPDATED=$d" \
        "PLACEHOLDER_NOTE=$note" > "$DIR/$id.md"
    else
      {
        echo "---"
        echo "id: $id"
        echo "title: $title"
        echo "type: standalone"
        echo "status: open"
        echo "created: $d"
        echo "updated: $d"
        echo "note: $note"
        echo "---"
        echo
        redaction_comment
        echo
        echo "## Summary"
        echo
        echo "## Context"
        echo
        echo "## Suggested skills"
        echo
      } > "$DIR/$id.md"
    fi
    echo "Created $DIR/$id.md (standalone/reference) — no claim needed; edit it freely."
  else
    if [ "$TOPOLOGY" = "cross-repo" ] && [ -z "$audience" ]; then
      # Shared board: no single default identity. Use the calling repo's env identity if present,
      # otherwise require an explicit --audience rather than defaulting to a stale/foreign name.
      if [ -n "${HANDOFF_REPO:-}" ]; then
        audience="$HANDOFF_REPO"
      else die "cross-repo board: pass --audience <repo> (which repo acts next) — a shared board has no default identity"; fi
    fi
    local tmpl
    tmpl="$(tmpl_path handoff-doc-template.md)"
    if [ -f "$tmpl" ]; then
      # PLACEHOLDER_* tokens (not {{...}} or <...>) so a prettier/lint pass on the shipped
      # template never mangles them before `handoff new` fills them in.
      render_tmpl "$tmpl" "PLACEHOLDER_ID=$id" "PLACEHOLDER_TITLE=$title" \
        "PLACEHOLDER_AUDIENCE=$audience" "PLACEHOLDER_SEVERITY=$severity" \
        "PLACEHOLDER_CREATED=$d" "PLACEHOLDER_UPDATED=$d" \
        "PLACEHOLDER_NOTE=$note" > "$DIR/$id.md"
    else
      {
        echo "---"
        echo "id: $id"
        echo "title: $title"
        echo "type: coordination"
        echo "status: open"
        [ -n "$audience" ] && echo "audience: $audience"
        echo "severity: $severity"
        echo "created: $d"
        echo "updated: $d"
        echo "note: $note"
        echo "---"
        echo
        redaction_comment
        echo
        echo "## Context"
        echo
        echo "## Verify"
        echo
        echo "## Suggested skills"
        echo
      } > "$DIR/$id.md"
    fi
    echo "Created $DIR/$id.md — claim it before working: ./handoff claim $id \"...\""
  fi
  echo "🔒 Before committing: redact secrets/keys/passwords/PII — this doc goes into git history."
  cmd_index
}

# Bring an existing file onto the board as a handoff (default type: standalone). Used to migrate
# reference docs. Never moves the source (the caller trashes it); we copy + normalize frontmatter.
cmd_import() {
  local src="" id="" title="" type="standalone" severity="" note=""
  src="${1:?usage: handoff import <file> [--id ID] [--title T] [--type standalone|coordination] [--severity S] [--note N]}"
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --id)
        id="${2:-}"
        shift 2
        ;;
      --title)
        title="${2:-}"
        shift 2
        ;;
      --type)
        type="${2:-}"
        shift 2
        ;;
      --severity)
        severity="${2:-}"
        shift 2
        ;;
      --note)
        note="${2:-}"
        shift 2
        ;;
      --standalone)
        type="standalone"
        shift
        ;;
      *) shift ;;
    esac
  done
  [ -f "$src" ] || die "no such file: $src"
  case "$type" in coordination | standalone) ;; *) die "bad --type: $type (use coordination|standalone)" ;; esac
  [ -n "$id" ] || id="$(basename "$src" .md)"
  # norm_id is the only sanitizer: it slugifies to lowercase kebab-case and appends the suffix, so
  # board files are always <id>-handoff.md. It rejects an id with nothing alphanumeric in it.
  id="$(norm_id "$id")" || die "could not derive a usable id from $src — pass --id"
  [ -f "$DIR/$id.md" ] || [ -f "$DIR/archive/$id.md" ] && die "$id already exists on the board"
  # title: --title, else the first markdown H1, else the id
  [ -n "$title" ] || title="$(sed -n 's/^# //p' "$src" | head -1)"
  [ -n "$title" ] || title="$id"
  local d
  d="$(today)" dest="$DIR/$id.md"

  if [ "$(head -1 "$src")" = "---" ]; then
    # Source already has YAML frontmatter — copy it, then upsert the board keys via set_field.
    cp "$src" "$dest"
    set_field "$dest" id "$id"
    set_field "$dest" title "$title"
    set_field "$dest" type "$type"
    [ -n "$(meta "$dest" status)" ] || set_field "$dest" status "open"
    [ -n "$(meta "$dest" created)" ] || set_field "$dest" created "$d"
    set_field "$dest" updated "$d"
    [ "$type" = "coordination" ] && [ -n "$severity" ] && set_field "$dest" severity "$severity"
  else
    # No frontmatter — prepend a fresh block above the content, verbatim.
    {
      echo "---"
      echo "id: $id"
      echo "title: $title"
      echo "type: $type"
      echo "status: open"
      [ "$type" = "coordination" ] && echo "severity: ${severity:-medium}"
      echo "created: $d"
      echo "updated: $d"
      echo "note: $note"
      echo "---"
      echo
    } > "$dest"
    cat "$src" >> "$dest"
  fi
  echo "Imported $src → $dest (type: $type)."
  echo "🔒 Before committing: redact secrets/keys/passwords/PII — this doc goes into git history."
  cmd_index
}

cmd_list() {
  printf '%-44s %-9s %-14s %-8s %s\n' ID STATUS AUDIENCE SEVERITY LOCK
  printf '%-44s %-9s %-14s %-8s %s\n' "$(printf '%.44s' "--------------------------------------------")" \
    "---------" "--------------" "--------" "----"
  local standalone="" orchestrators=""
  for f in "$DIR"/*-handoff.md; do
    [ -f "$f" ] || continue
    local base
    base="$(basename "$f" .md)"
    case "$base" in INDEX | README | handoff-doc-template | handoff-standalone-template | handoff-orchestrator-template) continue ;; esac
    if is_orchestrator "$f"; then
      local prog done total out
      prog="$(child_progress "$f")"
      done="${prog%%|*}"
      total="$(printf '%s' "$prog" | cut -d'|' -f2)"
      out="${prog#*|*|}"
      orchestrators="${orchestrators}$(printf '%-44s %-9s %s' "$base" "$done/$total done" "${out:-— all children done}")"$'\n'
      continue
    fi
    if is_standalone "$f"; then
      standalone="${standalone}$(printf '%-44s %-9s %s' "$base" "$(meta "$f" status)" "$(meta "$f" title)")"$'\n'
      continue
    fi
    local kind owner exp
    IFS='|' read -r kind owner exp <<< "$(lock_state "$base")"
    local lock='—'
    case "$kind" in
      held) lock="🔒 $owner until $(human "$exp")" ;;
      expired) lock="⚠️  STALE $owner (expired $(human "$exp")) — reclaimable" ;;
    esac
    printf '%-44s %-9s %-14s %-8s %s\n' \
      "$base" "$(meta "$f" status)" "$(meta "$f" audience)" "$(meta "$f" severity)" "$lock"
  done
  if [ -n "$orchestrators" ]; then
    printf '\nOrchestrators (bundles — progress derived from children, no claim needed):\n'
    printf '%-44s %-9s %s\n' ID PROGRESS OUTSTANDING
    printf '%s' "$orchestrators"
  fi
  if [ -n "$standalone" ]; then
    printf '\nStandalone / reference (no claim needed):\n'
    printf '%-44s %-9s %s\n' ID STATUS TITLE
    printf '%s' "$standalone"
  fi
}

cmd_claim() {
  local id="${1:?usage: handoff claim <id> [note]}"
  shift || true
  # accept the short or full id, in any casing; the lease is keyed on the resolved stem
  local raw_id="$id"
  id="$(resolve_id "$id")" || die "unusable id: '$raw_id' (needs at least one letter or digit)"
  local note="${*:-}"
  local f
  f="$(doc_of "$id")"
  is_standalone "$f" && die "$id is a standalone/reference handoff — no lease needed; just edit it."
  is_orchestrator "$f" && die "$id is an orchestrator (a bundle index) — no lease needed; claim one of its children instead."
  [ "$(meta "$f" status)" = "done" ] && die "$id is already done — nothing to claim"

  local kind owner exp
  IFS='|' read -r kind owner exp <<< "$(lock_state "$id")"
  if [ "$kind" = "held" ]; then
    die "$id is CLAIMED by $owner until $(human "$exp"). Do not work on it — pick another handoff, or ask $owner."
  fi

  # Atomic: mkdir fails if the directory already exists, so two racing agents
  # cannot both win the lease. Do not replace this with a frontmatter edit.
  # .locks/ itself is gitignored and may not exist on a fresh install — create the
  # parent (non-atomic, fine) so the per-id mkdir (atomic, the real lock) can run.
  mkdir -p "$LOCKS"
  if ! mkdir "$LOCKS/$id" 2> /dev/null; then
    die "$id was just claimed by someone else — re-run 'handoff list'"
  fi

  local me sess exp_new
  me="$(whoami_id)"
  sess="$(session_id)"
  exp_new="$(($(now) + TTL_HOURS * 3600))"
  {
    echo "owner=$me"
    echo "session=$sess" # raw id — the enforcement gate matches this against the tool payload
    echo "claimed=$(now)"
    echo "expires=$exp_new"
    echo "note=$note"
  } > "$LOCKS/$id/owner"

  if [ "$kind" = "expired" ]; then
    echo "⚠️  Took over an EXPIRED lease from $owner (expired $(human "$exp"))."
    log_activity "$f" "lease taken over from $owner (expired $(human "$exp")) by $me"
  fi
  echo "🔒 Claimed $id as $me for ${TTL_HOURS}h (until $(human "$exp_new")). Release it when you stop."
  cmd_index
}

cmd_touch() {
  local id="${1:?usage: handoff touch <id>}"
  id="$(resolve_id "$id")" || die "unusable id: '$1' (needs at least one letter or digit)"
  local kind owner exp
  IFS='|' read -r kind owner exp <<< "$(lock_state "$id")"
  [ "$kind" = "free" ] && die "$id is not claimed"
  # rewrite the lease with a fresh expiry, preserving the other fields
  local t
  t="$(mktemp)"
  grep -v '^expires=' "$LOCKS/$id/owner" > "$t"
  echo "expires=$(($(now) + TTL_HOURS * 3600))" >> "$t"
  cat "$t" > "$LOCKS/$id/owner"
  rm -f "$t"
  echo "Lease on $id extended ${TTL_HOURS}h."
}

cmd_release() {
  local id="${1:?usage: handoff release <id> --status open|blocked|done [--verified-by \"...\"] [--blocked-on \"...\"] [--run-verify] [note]}"
  shift
  local raw_id="$id"
  id="$(resolve_id "$id")" || die "unusable id: '$raw_id' (needs at least one letter or digit)"
  local status='' note='' verified_by='' blocked_on='' run_verify=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --status)
        status="${2:?}"
        shift 2
        ;;
      --verified-by)
        verified_by="${2:?}"
        shift 2
        ;;
      --blocked-on)
        blocked_on="${2:?}"
        shift 2
        ;;
      --run-verify)
        run_verify=1
        shift
        ;;
      *)
        note="$note $1"
        shift
        ;;
    esac
  done
  [ -n "$status" ] || die "release needs --status open|blocked|done"
  case "$status" in open | blocked | done) ;; *) die "bad status: $status" ;; esac

  local f
  f="$(doc_of "$id")"
  local me
  me="$(whoami_id)"

  if is_orchestrator "$f"; then
    # An orchestrator carries no lease of its own. `done` is the one place the bundle relationship
    # is enforced: a bundle is finished exactly when every child is finished, so closing it while a
    # child is still open (or names no file at all) is refused. That check is what stops an
    # orchestrator from becoming the stale summary doc it exists to replace.
    local prog pdone ptotal pout
    prog="$(child_progress "$f")"
    pdone="${prog%%|*}"
    ptotal="$(printf '%s' "$prog" | cut -d'|' -f2)"
    pout="${prog#*|*|}"
    case "$status" in
      open)
        set_field "$f" status open
        set_field "$f" updated "$(today)"
        log_activity "$f" "updated (orchestrator, $pdone/$ptotal children done) by $me.${note}"
        echo "Updated orchestrator $id — $pdone/$ptotal children done.${pout:+ Outstanding: $pout}"
        ;;
      done)
        [ "$ptotal" -gt 0 ] || die "$id has no children — add children: [...] before closing the bundle"
        [ "$pdone" -eq "$ptotal" ] || die "$id still has outstanding children: $pout"
        set_field "$f" status done
        set_field "$f" updated "$(today)"
        set_field "$f" verified_at "$(today)"
        log_activity "$f" "bundle complete — all $ptotal children done. Closed by $me.${note}"
        mkdir -p "$DIR/archive"
        if [ "$(dirname "$f")" = "$DIR" ]; then
          git -C "$DIR" mv "$(basename "$f")" "archive/$(basename "$f")" 2> /dev/null \
            || mv "$f" "$DIR/archive/" 2> /dev/null || true
        fi
        echo "✅ Bundle $id complete ($ptotal/$ptotal children done) → archive/."
        surface_unblocked "$id" # a doc may be blocked on this bundle landing
        ;;
      *) die "orchestrators support --status open|done (a bundle has no lease to block on)" ;;
    esac
    cmd_index
    return
  fi

  if is_standalone "$f"; then
    # A standalone/reference doc carries no lease and makes no live-code claim, so `done`
    # just retires it (archive) with no --verified-by. Only open|done apply.
    case "$status" in
      open)
        set_field "$f" status open
        set_field "$f" updated "$(today)"
        log_activity "$f" "updated (standalone) by $me.${note}"
        echo "Updated standalone $id."
        ;;
      done)
        set_field "$f" status done
        set_field "$f" updated "$(today)"
        log_activity "$f" "retired (standalone) by $me.${note}"
        mkdir -p "$DIR/archive"
        if [ "$(dirname "$f")" = "$DIR" ]; then
          git -C "$DIR" mv "$(basename "$f")" "archive/$(basename "$f")" 2> /dev/null \
            || mv "$f" "$DIR/archive/" 2> /dev/null || true
        fi
        echo "✅ Retired standalone $id → archive/."
        # Every path that closes a doc must announce its dependents. This branch is newer than the
        # unblock feature and originally skipped it, so anything blocked on a standalone deadlocked.
        surface_unblocked "$id"
        ;;
      *) die "standalone handoffs support --status open|done (there is no lease to block on)" ;;
    esac
    cmd_index
    return
  fi

  if [ "$status" = "blocked" ]; then
    [ -n "$blocked_on" ] || die "release --status blocked needs --blocked-on <handoff-id|\"external: ...\"> — what is it waiting on?"
    # A handoff id blocker is canonicalized to its filename stem; "external: ..." is left as-is
    # (that prefix exists precisely for blockers outside the board, which cannot be validated here).
    # A blocker names another doc on this board, so resolve it the same way as a claim target —
    # otherwise a legacy-named blocker would be recorded under a slug that matches no file.
    #
    # Then VALIDATE it. `blocked` is only meaningful if something can later close and release this
    # doc; an unvalidated blocker deadlocks silently — the doc sits blocked forever and is never
    # surfaced as unblocked, which is worse than refusing the release outright.
    case "$blocked_on" in
      external:*) ;;
      *)
        blocked_on="$(resolve_id "$blocked_on")" || die "unusable --blocked-on id: '$blocked_on'"
        [ "$blocked_on" = "$id" ] && die "$id cannot be blocked on itself — name the other handoff, or use --blocked-on \"external: ...\""
        [ -f "$DIR/$blocked_on.md" ] || [ -f "$DIR/archive/$blocked_on.md" ] \
          || die "no such handoff to block on: $blocked_on (file it first, or use --blocked-on \"external: ...\"). Nothing would ever close it."
        ;;
    esac
    set_field "$f" blocked_on "$blocked_on"
  fi

  if [ "$status" = "done" ]; then
    # done is a claim about the LIVE CODE, not about the doc. Require evidence.
    [ -n "$verified_by" ] || die "release --status done needs --verified-by \"<how you verified against live code>\" (e.g. a test run or file:line). Trust-closing is disabled."
    local vcmd
    vcmd="$(meta "$f" verify)"
    if [ -n "$vcmd" ]; then
      # SAFE BY DEFAULT: never auto-run a command from a doc (a cross-repo doc is
      # untrusted). Run only with BOTH an explicit flag AND the install-time opt-in,
      # and only for a doc whose origin is THIS repo.
      if [ "$run_verify" = 1 ] && [ "${HANDOFF_ALLOW_VERIFY_CMD:-0}" = 1 ] && doc_is_local "$f"; then
        echo "Running verify: $vcmd"
        if ! (cd "$(git rev-parse --show-toplevel 2> /dev/null || echo "$DIR")" && eval "$vcmd"); then
          die "verify command failed — not closing $id. Fix the code or the command."
        fi
        verified_by="$verified_by [verify: exit 0]"
      else
        echo "NOTE: this handoff carries a verify: command but it was NOT run"
        echo "      ($vcmd)"
        echo "      Run it yourself, or re-release with --run-verify (needs install opt-in HANDOFF_ALLOW_VERIFY_CMD=1 and a local doc)."
      fi
    fi
  fi

  set_field "$f" status "$status"
  set_field "$f" updated "$(today)"
  if [ "$status" = "done" ]; then
    set_field "$f" verified_at "$(today)"
    log_activity "$f" "done — verified against live code by $me: ${verified_by}.${note}"
    mkdir -p "$DIR/archive"
    if [ "$(dirname "$f")" = "$DIR" ]; then
      git -C "$DIR" mv "$(basename "$f")" "archive/$(basename "$f")" 2> /dev/null \
        || mv "$f" "$DIR/archive/" 2> /dev/null || true
    fi
    echo "✅ $id → done, moved to archive/. verified-by: $verified_by"
    echo "🔒 This doc is committed to git history — confirm no secrets/keys/passwords/PII remain."
    surface_unblocked "$id"
  else
    log_activity "$f" "$status — released by $me.${note}"
    echo "Released $id → $status."
  fi
  clear_lock "$id"
  cmd_index
}

doc_is_local() { # a doc "belongs to" this repo when repos: is unset or names REPO_NAME
  local f="$1" repos
  repos="$(meta "$f" repos)"
  [ -z "$repos" ] && return 0
  [ -z "$REPO_NAME" ] && return 0
  case "$repos" in *"$REPO_NAME"*) return 0 ;; *) return 1 ;; esac
}

surface_unblocked() { # closed_id -> print any open docs blocked_on it
  local closed="$1" found=0
  for g in "$DIR"/*-handoff.md; do
    [ -f "$g" ] || continue
    local gb
    gb="$(basename "$g" .md)"
    case "$gb" in INDEX | README | handoff-doc-template | handoff-standalone-template | handoff-orchestrator-template) continue ;; esac
    [ "$(meta "$g" status)" = "blocked" ] || continue
    case "$(meta "$g" blocked_on)" in *"$closed"*)
      [ "$found" = 0 ] && echo "Now unblocked (their blocker $closed is done):"
      found=1
      echo "  - $gb — $(meta "$g" title)"
      ;;
    esac
  done
  return 0
}

cmd_reap() { # show (and with --force, clear) expired leases
  local force="${1:-}"
  local found=0
  for d in "$LOCKS"/*/; do
    [ -d "$d" ] || continue
    local id
    id="$(basename "$d")"
    local kind owner exp
    IFS='|' read -r kind owner exp <<< "$(lock_state "$id")"
    [ "$kind" = "expired" ] || continue
    found=1
    echo "⚠️  $id — held by $owner, expired $(human "$exp")"
    if [ "$force" = "--force" ]; then
      clear_lock "$id"
      echo "   cleared."
    fi
  done
  [ "$found" = 0 ] && echo "No expired leases."
  return 0
}

cmd_index() {
  local out="$DIR/INDEX.md"
  {
    echo "<!-- GENERATED by ./handoff index — do not edit by hand. -->"
    echo "# Handoff Index"
    echo
    if [ "$TOPOLOGY" = "cross-repo" ]; then
      echo "Shared coordination board${REPO_NAME:+ (viewed as $REPO_NAME)}. Generated $(date '+%Y-%m-%d %H:%M')."
    else
      echo "Coordination board for ${REPO_NAME:-this repo}. Generated $(date '+%Y-%m-%d %H:%M')."
    fi
    echo "Claim before you work: \`./handoff claim <id>\`. Protocol: [README.md](./README.md)."
    echo
    echo "## Open"
    echo
    echo "| Handoff | Status | Acts next | Severity | Updated | Blocked on | Lease |"
    echo "| --- | --- | --- | --- | --- | --- | --- |"
    for f in "$DIR"/*-handoff.md; do
      [ -f "$f" ] || continue
      local base
      base="$(basename "$f" .md)"
      case "$base" in INDEX | README | handoff-doc-template | handoff-standalone-template | handoff-orchestrator-template) continue ;; esac
      # Neither standalone docs nor orchestrators are claimable work — an orchestrator listed here
      # reads as an unclaimed open task, which is the opposite of what the type means.
      is_standalone "$f" && continue
      is_orchestrator "$f" && continue
      local kind owner exp
      IFS='|' read -r kind owner exp <<< "$(lock_state "$base")"
      local lease="—"
      [ "$kind" = "held" ] && lease="🔒 $owner"
      [ "$kind" = "expired" ] && lease="⚠️ stale ($owner)"
      local bo
      bo="$(meta "$f" blocked_on)"
      [ -n "$bo" ] && is_archived "${bo%% *}" && bo="$bo ✅ resolved"
      echo "| [$(meta "$f" title)](./$base.md) | \`$(meta "$f" status)\` | $(meta "$f" audience) | $(meta "$f" severity) | $(meta "$f" updated) | ${bo:-—} | $lease |"
    done
    echo
    # Orchestrators: bundle indexes. Progress is derived from the children on every regeneration,
    # exactly as `handoff list` does it, so the index cannot drift from the children's real state.
    local has_orch=0
    for f in "$DIR"/*-handoff.md; do
      [ -f "$f" ] || continue
      local base
      base="$(basename "$f" .md)"
      case "$base" in INDEX | README | handoff-doc-template | handoff-standalone-template | handoff-orchestrator-template) continue ;; esac
      is_orchestrator "$f" || continue
      if [ "$has_orch" = 0 ]; then
        has_orch=1
        echo "## Orchestrators (bundles — no claim needed)"
        echo
        echo "| Bundle | Progress | Outstanding |"
        echo "| --- | --- | --- |"
      fi
      local prog pdone ptotal pout
      prog="$(child_progress "$f")"
      pdone="${prog%%|*}"
      ptotal="$(printf '%s' "$prog" | cut -d'|' -f2)"
      pout="${prog#*|*|}"
      echo "| [$(meta "$f" title)](./$base.md) | $pdone/$ptotal done | ${pout:-— all children done} |"
    done
    [ "$has_orch" = 1 ] && echo
    # Standalone / reference docs: self-contained, gate-exempt, no lease. Listed apart so they
    # are not mistaken for claimable work.
    local has_standalone=0
    for f in "$DIR"/*-handoff.md; do
      [ -f "$f" ] || continue
      local base
      base="$(basename "$f" .md)"
      case "$base" in INDEX | README | handoff-doc-template | handoff-standalone-template | handoff-orchestrator-template) continue ;; esac
      is_standalone "$f" || continue
      if [ "$has_standalone" = 0 ]; then
        has_standalone=1
        echo "## Standalone / reference (no claim needed)"
        echo
        echo "| Handoff | Status | Updated |"
        echo "| --- | --- | --- |"
      fi
      echo "| [$(meta "$f" title)](./$base.md) | \`$(meta "$f" status)\` | $(meta "$f" updated) |"
    done
    [ "$has_standalone" = 1 ] && echo
    echo "## Archive (done / superseded)"
    echo
    echo "| Handoff | Status | Verified |"
    echo "| --- | --- | --- |"
    for f in "$DIR"/archive/*-handoff.md; do
      [ -f "$f" ] || continue
      local base
      base="$(basename "$f" .md)"
      echo "| [$(meta "$f" title)](./archive/$base.md) | \`$(meta "$f" status)\` | $(meta "$f" verified_at) |"
    done
  } > "$out"
  echo "Wrote $out"
}

case "${1:-list}" in
  list) cmd_list ;;
  new)
    shift
    cmd_new "$@"
    ;;
  import)
    shift
    cmd_import "$@"
    ;;
  claim)
    shift
    cmd_claim "$@"
    ;;
  touch)
    shift
    cmd_touch "$@"
    ;;
  release)
    shift
    cmd_release "$@"
    ;;
  reap)
    shift
    cmd_reap "$@"
    ;;
  index) cmd_index ;;
  *) die "usage: handoff [list | new <id> [--type coordination|standalone|--standalone] [opts] | import <file> [--id ID] [--title T] [--type ...] | claim <id> [note] | touch <id> | release <id> --status open|blocked|done [--verified-by ...] [--blocked-on ...] [--run-verify] | reap [--force] | index]" ;;
esac
